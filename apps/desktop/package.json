{
  "name": "@myteam/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node ./scripts/ensure-electron.mjs && vite",
    "build": "node ./scripts/ensure-electron.mjs && tsc --noEmit && vite build && electron-builder --mac dir",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@myteam/client-core": "workspace:*",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "^7.9.4",
    "tailwind-merge": "^3.5.0",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^39.1.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.1"
  },
  "build": {
    "appId": "ai.myteam.desktop",
    "asar": true,
    "productName": "MyTeam",
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ]
    }
  }
}
