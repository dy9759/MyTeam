# Database
POSTGRES_DB=myteam
POSTGRES_USER=myteam
POSTGRES_PASSWORD=myteam
POSTGRES_PORT=5432
DATABASE_URL=postgres://myteam:myteam@localhost:5432/myteam?sslmode=disable

# Server
PORT=8080
JWT_SECRET=change-me-in-production
MYTEAM_SERVER_URL=ws://localhost:8080/ws
MYTEAM_APP_URL=http://localhost:3000
MYTEAM_DAEMON_CONFIG=
MYTEAM_WORKSPACE_ID=
MYTEAM_DAEMON_ID=
MYTEAM_DAEMON_DEVICE_NAME=
MYTEAM_DAEMON_POLL_INTERVAL=3s
MYTEAM_DAEMON_HEARTBEAT_INTERVAL=15s
MYTEAM_CODEX_PATH=codex
MYTEAM_CODEX_MODEL=
MYTEAM_CODEX_WORKDIR=
MYTEAM_CODEX_TIMEOUT=20m

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@myteam.ai

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Doubao / Miaoji ASR (Feishu 豆包语音妙记)
# Docs: https://www.volcengine.com/docs/6561/1798094
# Read by server/internal/service/meeting_transcriber.go
MYTEAM_DOUBAO_APP_ID=
MYTEAM_DOUBAO_ACCESS_TOKEN=
MYTEAM_DOUBAO_RESOURCE_ID=volc.lark.minutes
# Optional — defaults baked into code
MYTEAM_DOUBAO_MEMO_SUBMIT_URL=
MYTEAM_DOUBAO_MEMO_QUERY_URL=

# S3 / CloudFront
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=myteam/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=

# Frontend
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Remote API (optional) — set to proxy local frontend to a remote backend
# Leave empty to use local backend (localhost:8080)
# REMOTE_API_URL=https://myteam-api.copilothub.ai

# ──────────────────────────────────────────────────────────────────────
# Personal Agent — Claude Agent SDK kernel
# ──────────────────────────────────────────────────────────────────────
# Kernel: "openai_compat" (default — Bailian/DashScope/OpenAI-compatible) or "anthropic"
AGENT_KERNEL=openai_compat
AGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=qwen-plus
AGENT_SYSTEM_PROMPT=
# Optional overrides for the Python subprocess runtime
# AGENT_RUNNER_PYTHON=python3
# AGENT_RUNNER_SCRIPT_PATH=
